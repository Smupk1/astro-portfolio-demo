---
interface Props { size?: number }
const { size = 200 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 200 200">
  {[0, 90, 180, 270].map(a => (
    <g transform={`rotate(${a} 100 100)`}>
      <path d="M 100 100 C 70 70, 60 40, 100 30 C 140 40, 130 70, 100 100 Z" fill="var(--olive)"></path>
    </g>
  ))}
  {[45, 135, 225, 315].map(a => (
    <g transform={`rotate(${a} 100 100)`}>
      <path d="M 100 100 C 80 80, 75 55, 100 50 C 125 55, 120 80, 100 100 Z" fill="var(--olive-deep)"></path>
    </g>
  ))}
  <circle cx="100" cy="100" r="14" fill="var(--garnet)"></circle>
  <circle cx="100" cy="100" r="14" fill="none" stroke="var(--garnet-deep)" stroke-width="1.5"></circle>
</svg>
